# YANGI .env FAYL YARATING VA
# QUYIDAGI MA'LUMOTLARNI YOZING:

# ========================
# BOT SOZLAMALARI
# ========================
ADMINS=12345678,12345677,12345676
BOT_TOKEN=123452345243:Asdfasdfasf

# ========================
# DATABASE SOZLAMALARI
# ========================
# Database turi: sqlite / mysql / postgresql
# Standart: sqlite (lokal file-based DB)
DB_TYPE=mysql

# MySQL sozlamalari (agar DB_TYPE=mysql bo'lsa)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=shop_db

# PostgreSQL sozlamalari (agar DB_TYPE=postgresql bo'lsa)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=shop_db

# ========================
# BOSHQA SOZLAMALAR
# ========================
# Server IP (admin notifikatsiyalari uchun)
ip=localhost
TIMEZONE=Asia/Tashkent
